\n            font-size: 22px;\n            color: #5d4037;\n            margin-bottom: 15px;\n            line-height: 1.6;\n        }\n\n        .english-div {\n            font-size: 16px;\n            color: #666;\n            margin-bottom: 10px;\n            line-height: 1.5;\n        }\n\n        .source-div {\n            font-size: 14px;\n            color: #795548;\n            font-style: italic;\n            text-align: right;\n        }\n    \u003c/style\u003e\n\u003c/head\u003e\n\u003cbody\u003e\n    \u003cdiv class=\"root-container1\"\u003e\n        \u003cdiv class=\"main-container1\"\u003e\n            \u003cdiv class=\"header-div\"\u003e\n                सुविचार / Thoughts\n            \u003c/div\u003e\n            \u003cdiv class=\"content-div\"\u003e\n                \u003cdiv class=\"sadvakya-container\"\u003e\n                    \u003cdiv class=\"hindi-div\"\u003eअहं ब्रह्मास्मि\u003c/div\u003e\n                    \u003cdiv class=\"english-div\"\u003eI am Brahman (The Ultimate Reality)\u003c/div\u003e\n                    \u003cdiv class=\"source-div\"\u003e- Brihadaranyaka Upanishad 1.4.10\u003c/div\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class=\"sadvakya-container\"\u003e\n                    \u003cdiv class=\"hindi-div\"\u003eतत्त्वमसि\u003c/div\u003e\n                    \u003cdiv class=\"english-div\"\u003eThat Thou Art (You are That)\u003c/div\u003e\n                    \u003cdiv class=\"source-div\"\u003e- Chandogya Upanishad 6.8.7\u003c/div\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class=\"sadvakya-container\"\u003e\n                    \u003cdiv class=\"hindi-div\"\u003eप्रज्ञानं ब्रह्म\u003c/div\u003e\n                    \u003cdiv class=\"english-div\"\u003eConsciousness is Brahman\u003c/div\u003e\n                    \u003cdiv class=\"source-div\"\u003e- Aitareya Upanishad 3.3\u003c/div\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class=\"sadvakya-container\"\u003e\n                    \u003cdiv class=\"hindi-div\"\u003eअयं आत्मा ब्रह्म\u003c/div\u003e\n                    \u003cdiv class=\"english-div\"\u003eThis Self is Brahman\u003c/div\u003e\n                    \u003cdiv class=\"source-div\"\u003e- Mandukya Upanishad 1.2\u003c/div\u003e\n                \u003c/div\u003e\n\n                \u003cdiv class=\"sadvakya-container\"\u003e\n                    \u003cdiv class=\"hindi-div\"\u003eसोऽहम्\u003c/div\u003e\n                    \u003cdiv class=\"english-div\"\u003eI am That (He)\u003c/div\u003e\n                    \u003cdiv class=\"source-div\"\u003e- Vedantic Teaching\u003c/div\u003e\n                \u003c/div\u003e\n            \u003c/div\u003e\n        \u003c/div\u003e\n    \u003c/div\u003e\n\n    \u003cscript\u003e\n        // Get all the Mahāvākya containers\n        const containers = document.querySelectorAll('.sadvakya-container');\n\n        // Select a random container to display\n        const randomIndex = Math.floor(Math.random() * containers.length);\n        containers[randomIndex].style.display = 'block';\n    \u003c/script\u003e\n\u003c/body\u003e\n\u003c/html\u003e","title":"Motivation Thoughts","url":"http://localhost:1313/suvichar/"},{"date":"2024-11-08T19:23:23+05:30","summary":"","title":"New Baner","url":"http://localhost:1313/new-baner/"},{"date":"2024-11-08T19:23:23+05:30","summary":"","title":"Notification: New Updates","url":"http://localhost:1313/download/"},{"date":"2024-11-08T19:23:23+05:30","summary":"","title":"Notification: New Updates","url":"http://localhost:1313/notification/"},{"date":"2024-11-08T19:23:23+05:30","summary":"","title":"Notification: New Updates","url":"http://localhost:1313/open/"},{"date":"2024-11-08T19:23:23+05:30","summary":"","title":"Post-Lists","url":"http://localhost:1313/post-list/"},{"date":"2024-11-08T19:23:23+05:30","summary":"","title":"Redirect","url":"http://localhost:1313/yp/"},{"date":"2024-11-08T19:23:23+05:30","summary":"","title":"Sar